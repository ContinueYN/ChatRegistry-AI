{
  "name": "tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test:unit": "vitest",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:coverage": "vitest --coverage",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "marked": "^16.4.1",
    "router": "^2.2.0",
    "three": "^0.180.0",
    "vue": "^3.5.22",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.18.6",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.4",
    "@vue/tsconfig": "^0.8.1",
    "cypress": "^14.0.3",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.9.0",
    "vite": "^7.1.7",
    "vite-plugin-vue-devtools": "^8.0.2",
    "vitest": "^2.1.8",
    "vue-tsc": "^3.1.0"
  }
}
